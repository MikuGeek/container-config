[Unit]
Description=Tailscale sidecar for <stack>
After=network-online.target
After=<stack>-pod.service
Requires=<stack>-pod.service
Wants=network-online.target

[Container]
Image=docker.io/tailscale/tailscale:stable
ContainerName=tailscale-<stack>
HostName=<stack>
Pod=<stack>.pod

Environment=TS_EXTRA_ARGS=--advertise-tags=tag:service-nonsensitive
Environment=TS_STATE_DIR=/var/lib/tailscale
Environment=TS_SERVE_CONFIG=/serve.json
Environment=TS_USERSPACE=true
EnvironmentFile=%h/container-config/env/shared/tailscale.env

Volume=%h/container-data/<stack>/tailscale-state:/var/lib/tailscale:Z,U
Volume=%h/container-config/<stack>/tailscale-serve.json:/serve.json:Z,U

Label=io.containers.autoupdate=registry

[Service]
Restart=always

[Install]
WantedBy=default.target
